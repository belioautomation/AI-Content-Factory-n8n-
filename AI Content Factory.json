      "name": "Research Agent"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a 1000-word SEO blog article.\n\nTopic:\n{{ $('Set').item.json.title }}\n\nResearch Summary:\n{{ $node[\"Node 4\"].json.output }}\n\nRequirements:\n- 1000 words\n- SEO optimized\n- Use headings (H1, H2)\n- Include introduction and conclusion\n- Add call to action at the end\n- Output in Markdown",
        "messages": {
          "messageValues": [
            {
              "message": "You are a professional SEO blog writer.  You write clear, engaging, and well-structured articles that are optimized for search engines.  Rules: - Always use proper Markdown formatting - Always include H1 title and H2 headings - Keep tone informative but engaging - Make content easy to read - Focus on SEO keywords naturally - End with a strong conclusion and call to action"
            }
          ]
        },
        "batching": {}
      },
