    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this article:\n\nTitle:\n{{ $json.title }}\n\nContent:\n{{ $json.content }}\n\nSource URL:\n{{ $json.url }}\n\nProvide:\n\n1. Short summary (3–5 sentences)\n2. Key points (bullet list)\n3. Important facts or data\n4. Why this topic matters\n5. Possible angles for a blog post",
        "messages": {
          "messageValues": [
            {
              "message": "You are a professional research assistant and content analyst.  Your job is to extract useful information from articles and prepare structured insights for a blog writer.  Rules: - Focus only on important and relevant information - Ignore fluff or irrelevant details - Extract key facts, trends, and insights - Summarize clearly and concisely - Do NOT write a blog post - Do NOT add opinions unless clearly implied by the text - Output structured notes for a writer to use"
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        240,
        0
